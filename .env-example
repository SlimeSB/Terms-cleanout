# ─── AI Agent 配置 ────────────────────────────────────────────────
# API 密钥（必填）
OPENAI_API_KEY=sk-your-api-key-here

# API 地址（可选，默认 https://api.openai.com/v1）
# 支持任何 OpenAI 兼容 API，如 DeepSeek、Ollama、Azure OpenAI 等
# OPENAI_BASE_URL=https://api.deepseek.com

# 模型名（可选，默认 gpt-4o-mini）
# LLM_MODEL=gpt-4o-mini
